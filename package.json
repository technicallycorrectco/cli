{
  "name": "@technicallycorrect/cli",
  "version": "1.0.0",
  "description": "Technically Correct CLI",
  "main": "./dist/index.js",
  "bin": {
    "tc": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "generate": "openapi-ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "precommit": "npm run format && npm run build && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/technicallycorrectco/cli.git"
  },
